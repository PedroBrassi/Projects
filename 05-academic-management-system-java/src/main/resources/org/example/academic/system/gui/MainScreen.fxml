<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academic.system.gui.MainScreenController">

    <top>
        <VBox alignment="CENTER" spacing="4">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Sistema Acadêmico"
                   style="-fx-font-size:24px; -fx-font-weight:bold;"/>
            <Label fx:id="lblWelcome"/>
        </VBox>
    </top>

    <center>

        <VBox spacing="15"
              alignment="CENTER">

            <padding>
                <Insets top="30"
                        right="30"
                        bottom="30"
                        left="30"/>
            </padding>

            <Button text="Cadastrar Turma"
                    prefWidth="250"
                    onAction="#openClassRegistration"/>

            <Button text="Cadastrar Avaliação"
                    prefWidth="250"
                    onAction="#openAssessmentRegistration"/>

            <Button text="Visualizar Dados"
                    prefWidth="250"
                    onAction="#openVisualization"/>

            <Button text="Configurar Persistência"
                    prefWidth="250"
                    onAction="#openPersistence"/>

            <Button text="Relatórios"
                    prefWidth="250"
                    onAction="#openReports"/>

            <Button text="Sair (Logout)"
                    prefWidth="250"
                    onAction="#logout"/>

        </VBox>

    </center>

</BorderPane>
