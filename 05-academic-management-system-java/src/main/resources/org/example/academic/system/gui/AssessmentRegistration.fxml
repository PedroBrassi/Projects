<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academic.system.gui.AssessmentRegistrationController">

    <top>
        <Label text="Cadastro de Avaliações"
               style="-fx-font-size:22px;-fx-font-weight:bold;"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>

        <GridPane alignment="CENTER"
                  hgap="10"
                  vgap="10">

            <padding>
                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>
            </padding>

            <Label text="Código da Turma"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtClassCode"
                       promptText="Ex.: POO2026"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"/>

            <Label text="Tipo"
                   GridPane.rowIndex="1"
                   GridPane.columnIndex="0"/>

            <ComboBox fx:id="cbType"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="1"/>

            <Label text="Nome"
                   GridPane.rowIndex="2"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtName"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="1"/>

            <Label text="Peso (0.0 - 1.0)"
                   GridPane.rowIndex="3"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtWeight"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="1"/>

            <Label text="Nota (0.0 - 10.0)"
                   GridPane.rowIndex="4"
                   GridPane.columnIndex="0"/>

            <TextField fx:id="txtMaximumScore"
                       GridPane.rowIndex="4"
                       GridPane.columnIndex="1"/>

            <HBox spacing="10"
                  alignment="CENTER"
                  GridPane.rowIndex="5"
                  GridPane.columnIndex="1">

                <Button text="Cadastrar"
                        onAction="#registerAssessment"/>

                <Button text="Voltar"
                        onAction="#goBack"/>

            </HBox>

        </GridPane>

    </center>

</BorderPane>
