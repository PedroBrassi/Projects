<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academic.system.gui.ClassRegistrationController">

    <top>
        <Label text="Cadastro de Turma"
               style="-fx-font-size:22px; -fx-font-weight:bold;"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>

        <GridPane hgap="10"
                  vgap="10"
                  alignment="CENTER">

            <padding>
                <Insets top="25" right="25" bottom="25" left="25"/>
            </padding>

            <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtCode"
                       promptText="Ex.: POO2026"
                       GridPane.rowIndex="0"
                       GridPane.columnIndex="1"/>

            <Label text="Nome:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="txtName"
                       promptText="Programação Orientada a Objetos"
                       GridPane.rowIndex="1"
                       GridPane.columnIndex="1"/>

            <Label text="Professor:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="txtProfessor"
                       promptText="Nome do professor"
                       GridPane.rowIndex="2"
                       GridPane.columnIndex="1"/>

            <Label text="Semestre:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="txtSemester"
                       promptText="2026/1"
                       GridPane.rowIndex="3"
                       GridPane.columnIndex="1"/>

            <HBox spacing="15"
                  alignment="CENTER"
                  GridPane.rowIndex="4"
                  GridPane.columnIndex="1">

                <Button text="Cadastrar"
                        onAction="#registerClass"/>

                <Button text="Voltar"
                        onAction="#goBack"/>

            </HBox>

        </GridPane>

    </center>

</BorderPane>
