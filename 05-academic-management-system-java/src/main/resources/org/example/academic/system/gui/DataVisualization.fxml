<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.academic.system.gui.DataVisualizationController">

    <top>

        <Label text="Visualização de Dados"
               style="-fx-font-size:22px;-fx-font-weight:bold;"
               BorderPane.alignment="CENTER"/>

    </top>

    <center>

        <VBox spacing="20">

            <padding>

                <Insets top="20"
                        right="20"
                        bottom="20"
                        left="20"/>

            </padding>

            <Label text="Turmas"/>

            <TableView fx:id="tableClasses"
                       prefHeight="200"/>

            <Label text="Avaliações"/>

            <TableView fx:id="tableAssessments"
                       prefHeight="200"/>

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="Atualizar"
                        onAction="#refreshData"/>

                <Button text="Voltar"
                        onAction="#goBack"/>

            </HBox>

        </VBox>

    </center>

</BorderPane>
